# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# ===== Band =====
# Human/user key from Band ("band_u_..."). Powers the orchestrator REST calls.
BAND_API_KEY=
# Optional. Per-run rooms are created on demand, so this is unused by default.
BAND_ROOM_ID=

# ===== Agent IDs + Keys (one pair per agent) =====
# From the Band dashboard → Agents. Each key starts with "band_a_".
BAND_AGENT_ID_INTAKE=
BAND_AGENT_KEY_INTAKE=

BAND_AGENT_ID_PARSER=
BAND_AGENT_KEY_PARSER=

BAND_AGENT_ID_DISCOVERER=
BAND_AGENT_KEY_DISCOVERER=

BAND_AGENT_ID_ANALYZER=
BAND_AGENT_KEY_ANALYZER=

# ===== Agent Handles (used for @mentions in Band rooms) =====
# Format: @<workspace>/<agent-slug>
HANDLE_INTAKE=
HANDLE_PARSER=
HANDLE_DISCOVERER=
HANDLE_ANALYZER=

# ===== Model Providers =====
# Featherless powers intake / discoverer / parser (Qwen2.5-32B-Instruct).
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# AI/ML API powers the analyzer (gpt-4o-mini).
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1

# ===== Deploy-only =====
# Comma-separated list of origins allowed to call the API. Set to your Vercel
# domain in production. Defaults to localhost for dev.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
